  object Memo1: TMemo
    Left = 0
    Top = 0
    Width = 367
    Height = 302
    Margins.Left = 2
    Margins.Top = 2
    Margins.Right = 2
    Margins.Bottom = 2
    Align = alClient
    Color = clWhite
    PopupMenu = PopupMenu1
    ScrollBars = ssBoth
    TabOrder = 1
    OnChange = Memo1Change
    OnKeyDown = Memo1KeyDown
  end
  object PopupMenu1: TPopupMenu
    Left = 80
    Top = 64
    object Links1: TMenuItem
      Caption = '&Execute'
      object MIElement: TMenuItem
        Caption = '&Element'
        Hint = 'Go to a selected element in the system'
        ShortCut = 16453
        OnClick = MIElementClick
      end
      object MIGoto: TMenuItem
        Caption = '&Goto'
        Hint = 'Go to a given line in the program script'
        ShortCut = 16455
        OnClick = MIGotoClick
      end
      object MILabel: TMenuItem
        Caption = '&Label'
        Hint = 'Insert a label for Goto statements'
        OnClick = MILabelClick
      end
      object MIMessage: TMenuItem
        Caption = '&Message'
        Hint = 'Display a message'
        OnClick = MIMessageClick
      end
    end
    object Internet1: TMenuItem
      Caption = '&Internet'
      object MIMailto: TMenuItem
        Caption = '&MailTo'
        Hint = 'Send an e-mail'
        OnClick = MIMailtoClick
      end
      object MIURL: TMenuItem
        Caption = '&URL'
        Hint = 'Open a web page'
        OnClick = MIURLClick
      end
    end
    object Learning1: TMenuItem
      Caption = '&Learn'
      object MIDismiss: TMenuItem
        Caption = 'Dismiss'
        Hint = 'Dismiss the current element'
        OnClick = MIDismissClick
      end
      object MILearn: TMenuItem
        Caption = '&Learn'
        Hint = 'Start learning'
        ShortCut = 16460
        OnClick = MILearnClick
      end
    end
    object Playing1: TMenuItem
      Caption = '&Playing'
      object MIFrame: TMenuItem
        Caption = 'Frame'
        Hint = 
          'Display an animation frame in an image component or in the backg' +
          'round'
        OnClick = MIFrameClick
      end
      object MIPlay: TMenuItem
        Caption = '&Play'
        Hint = 
          'Play sound or video associated with a given component (wait unti' +
          'l it is finished)'
        ShortCut = 16464
        OnClick = MIPlayClick
      end
      object MIStart: TMenuItem
        Caption = '&Start'
        Hint = 
          'Start playing a video or sound device and continue execution of ' +
          'the script'
        ShortCut = 16468
        OnClick = MIStartClick
      end
      object MIStop: TMenuItem
        Caption = 'Stop'
        Hint = 'Stop playing sounds and videos'
        OnClick = MIStopClick
      end
      object MIUPlay: TMenuItem
        Caption = '&UPlay'
        Hint = 'Play the sound recorded by the user'
        OnClick = MIUPlayClick
      end
      object MIWait: TMenuItem
        Caption = '&Wait'
        Hint = 
          'Wait a given number of milliseconds (1 second = 1000 millisecond' +
          's)'
        ShortCut = 16471
        OnClick = MIWaitClick
      end
      object MIWaitFrame: TMenuItem
        Caption = 'Wait&Frame'
        Hint = 
          'Wait until a given video frame or sound sample is reached in vid' +
          'eo/sound components'
        OnClick = MIWaitFrameClick
      end
    end
    object Showing1: TMenuItem
      Caption = '&Showing'
      object MIDisplay: TMenuItem
        Caption = '&Display'
        Hint = 'Change the image displayed by an image component'
        ShortCut = 16452
        OnClick = MIDisplayClick
      end
      object MIFont: TMenuItem
        Caption = '&Font'
        Hint = 
          'Assign a given registry font to a selected text, spell-pad or so' +
          'und component'
        ShortCut = 16454
        OnClick = MIFontClick
      end
      object MIHide: TMenuItem
        Caption = '&Hide'
        Hint = 'Hide a component '
        ShortCut = 16456
        OnClick = MIHideClick
      end
      object MIMove: TMenuItem
        Caption = '&Move'
        Hint = 'Move a component to a new location'
        OnClick = MIMoveClick
      end
      object MIShow: TMenuItem
        Caption = '&Show'
        Hint = 'Show a component (if hidden)'
        ShortCut = 16467
        OnClick = MIShowClick
      end
      object MITextOut: TMenuItem
        Caption = '&TextOut'
        Hint = 'Set text in a given text or sound component'
        ShortCut = 16472
        OnClick = MITextOutClick
      end
      object MIToggle: TMenuItem
        Caption = 'Toggle'
        Hint = 'Hide a visible component or show a hidden component'
        OnClick = MIToggleClick
      end
      object MITranslate: TMenuItem
        Caption = '&Translate'
        Hint = 'Display text component translation in place of the original text'
        OnClick = MITranslateClick
      end
    end
    object SuperMemo1: TMenuItem
      Caption = 'SuperMemo'
      object MILevel: TMenuItem
        Caption = '&Level'
        Hint = 'Set programs level (beginner, basic, middle, etc.)'
        OnClick = MILevelClick
      end
      object MIMode: TMenuItem
        Caption = '&Mode'
        Hint = 'Set the access mode to Read-Only, Learn-Only or to Full Access'
        OnClick = MIModeClick
      end
      object MIStatus: TMenuItem
        Caption = 'Status'
        Hint = 'Show or hide the status bar'
        OnClick = MIStatusClick
      end
      object MITips: TMenuItem
        Caption = 'Tips'
        Hint = 'Run Question of the Day dialog'
        OnClick = MITipsClick
      end
    end
    object Tests1: TMenuItem
      Caption = '&Tests'
      object MIDragMatchM: TMenuItem
        Caption = '&DragMatch (multiple)'
        Hint = 
          'Allow drag-and-match exercise for multiple labels and multiple p' +
          'ictures'
        OnClick = MIDragMatchMClick
      end
      object MIDragMatchS: TMenuItem
        Caption = 'DragMatch (&single)'
        Hint = 
          'Allow drag-and-match exercise for multiple labels and a single p' +
          'icture'#39's match rectangles'
        OnClick = MIDragMatchSClick
      end
      object MIDragTextMode: TMenuItem
        Caption = 'DragText&Mode'
        Hint = 'Allow transparent text dragged on an image component'
        OnClick = MIDragTextModeClick
      end
      object MIHitTest: TMenuItem
        Caption = '&HitTest'
        Hint = 
          'Put the element into hit-test mode that expects a grade from cli' +
          'cking the proper hit area'
        OnClick = MIHitTestClick
      end
      object WaitGrade1: TMenuItem
        Caption = '&WaitGrade'
        Hint = 'Wait until a grade is determined at repetitions'
        OnClick = WaitGrade1Click
      end
    end
    object Comment1: TMenuItem
      Caption = 'Comment'
      Hint = 'Put a comment separated by a semicolon'
      OnClick = Comment1Click
    end
  end
end
